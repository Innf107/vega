-- type: print(6)

import internal:Internal (debugInt)

data List(a) =
    | Nil
    | Cons(a, List(a))

map : forall a b. (a -> b, List(a)) -> List(b)
map(f, list) = match list {
   Nil -> Nil
   Cons(x, xs) -> Cons(f(x), map(f,xs))
}

sum : List(Int) -> Int
sum(list) = match list {
    Nil -> 0
    Cons(x, xs) -> x + sum(xs)
}

id : forall a. a -> a
id(x) = x

main : () -> ()
main() = {
    let list = map(id, Cons(1,Cons(2,Cons(3,Nil))))
    debugInt(sum(list))
}

