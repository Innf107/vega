-- type: print(3)

import internal:Internal (replicateArray, unsafeReadArray, unsafeFreezeArray, debugInt)

data Complex =
    | A(Int, Int, Int)
    | B(Int, Int)

main : () -> ()
main() = {
    let array = unsafeFreezeArray(replicateArray(5, B(1, 2)))
    match unsafeReadArray(array, 3) {
        A(_, _, _) -> {}
        B(x, y) -> {
            debugInt(x + y)
        }
    }
}
