-- type: print(1)

import internal:Internal (debugInt)

id : forall a. a -> a
id(x) = x

main : () -> ()
main() = {
    let x = id(1)
    let g(y : Bool) = if y then {
        let z = id(2)
        let h() = {
            g(z > 3)
        }
        h()
    } else {
        debugInt(x)
    }
    g(True)
}

