-- EXPECT: 4

data List : (Type -> Type) {
    Nil : forall a. List a;
    Cons : forall a. a -> List a -> List a;
};

map : forall a b. (a -> b) -> List a -> List b;
map f list = case list {
    Nil -> Nil;
    Cons x xs -> Cons (f x) (map f xs);
};

sum : List Int -> Int;
sum list = case list {
    Nil -> 0;
    Cons x xs -> x + sum xs;
};

main : Unit;
main = debug(sum(map (\x -> x + 1) (Cons 1 (Cons 2 Nil))));
